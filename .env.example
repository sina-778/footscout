# FootScout Environment Configuration
# Copy this file to .env and fill in your values

# ─── Weights & Biases ─────────────────────────────────────
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=footscout
WANDB_ENTITY=your_wandb_username

# ─── Scraper Settings ──────────────────────────────────────
# Delay between HTTP requests (seconds) — keep ≥ 1.0 to be respectful
SCRAPER_DELAY_S=1.2

# ─── Kaggle Fallback ───────────────────────────────────────
# Set to "true" to skip live scraping and use Kaggle FIFA dataset instead
# Download from: https://www.kaggle.com/datasets/stefanoleone992/fifa-22-complete-player-dataset
# Place the CSV at: data/raw/kaggle_fallback.csv
USE_KAGGLE_FALLBACK=false

# ─── Player Entry Threshold ────────────────────────────────
# Players with fewer minutes than this are excluded from the pipeline
MIN_MINUTES=450

# ─── Embedding Defaults ────────────────────────────────────
DEFAULT_EMB_METHOD=umap
DEFAULT_N_COMPONENTS=32
DEFAULT_ALPHA=0.6
